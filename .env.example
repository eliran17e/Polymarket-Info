# Copy to .env and adjust as needed. .env is gitignored — never commit real secrets.

# Postgres connection (matches docker-compose.yml).
# Uses the psycopg (v3) driver via SQLAlchemy.
DATABASE_URL=postgresql+psycopg://polymarket:polymarket@localhost:5434/polymarket

# How often the poller fetches fresh data, in seconds. ~60s is plenty (Gamma caches 30-60s).
POLL_INTERVAL_SECONDS=60

# Gemini API key — lives on the backend only, never the frontend.
GEMINI_API_KEY=
# Free-tier Flash/Flash-Lite model for the explainer (never Pro). Default tracks latest.
GEMINI_MODEL=gemini-flash-lite-latest

# Optional: gnews.io key (free tier, 100 req/day) for real article photos in the
# news sidebar. Leave empty to use Google News RSS + source favicons instead.
GNEWS_API_KEY=
